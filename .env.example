# ──────────────────────────────────────────────
# Village Tree - Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env.local and update values for your environment
# Never commit sensitive values to the repository

# ──────────────────────────────────────────────
# Symfony Configuration
# ──────────────────────────────────────────────
APP_ENV=dev
APP_SECRET=change_me

# ──────────────────────────────────────────────
# JWT Authentication Configuration
# ──────────────────────────────────────────────
JWT_SECRET_KEY=/var/www/backend/config/jwt/private.pem
JWT_PUBLIC_KEY=/var/www/backend/config/jwt/public.pem
JWT_PASSPHRASE=change_me

# ──────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=village_tree
MYSQL_USER=village_tree_user
MYSQL_PASSWORD=village_tree
DB_PORT=3306

# ──────────────────────────────────────────────
# Docker Port Configuration
# ──────────────────────────────────────────────
BACKEND_PORT=8080
